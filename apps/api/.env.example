DATABASE_URL="postgresql://lumi:lumi@localhost:5432/lumi?schema=public"
JWT_ACCESS_SECRET="troque-este-segredo-de-acesso"
JWT_REFRESH_SECRET="troque-este-segredo-de-refresh"
PORT=3333

# IA de geração (Gemini). Sem chave → provider mock offline.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Voz (ElevenLabs). Sem chave → provider mock (só timings do karaokê).
ELEVENLABS_API_KEY=""

# Cloudflare R2 (object storage: imagens + áudio). Sem chaves → storage off (fallback).
R2_BUCKET="lumi"
R2_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://lumi.afonsodev.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
